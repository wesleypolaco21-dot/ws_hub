    lbl.TextSize = 12
    lbl.TextColor3 = S.label
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextWrapped = true

    -- Toggle switch
    local sw = Instance.new("Frame", row)
    sw.Size = UDim2.new(0, 38, 0, 20)
    sw.Position = UDim2.new(1, -46, 0.5, -10)
    sw.BackgroundColor3 = initState and S.toggleOn or S.toggleOff
    sw.BorderSizePixel = 0
    Instance.new("UICorner", sw).CornerRadius = UDim.new(1, 0)

    local dot = Instance.new("Frame", sw)
    dot.Size = UDim2.new(0, 14, 0, 14)
    dot.Position = initState and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
    dot.BackgroundColor3 = S.dot
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local isOn = initState
    local function SetState(s)
        isOn = s
        TweenService:Create(sw,  TweenInfo.new(0.15), {BackgroundColor3 = s and S.toggleOn or S.toggleOff}):Play()
        TweenService:Create(dot, TweenInfo.new(0.15), {Position = s and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)}):Play()
    end

    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.MouseButton1Click:Connect(function()
        onChange(not isOn, SetState)
    end)
    return row, SetState
end

