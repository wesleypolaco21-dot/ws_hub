    local function updateAbToggleVisual()
        TweenService:Create(abDot, TweenInfo.new(0.15), {
            Position = autoBuyActive and UDim2.new(1,-17,0.5,-7.5) or UDim2.new(0,2,0.5,-7.5)
        }):Play()
        TweenService:Create(abSw, TweenInfo.new(0.15), {
            BackgroundColor3 = autoBuyActive and Theme.Accent1 or Theme.SurfaceHighlight
        }):Play()
