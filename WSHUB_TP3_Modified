local function ApplyViewportUIScale(targetFrame, designWidth, designHeight, minScale, maxScale)
    if not targetFrame then return end
    
    local existing = targetFrame:FindFirstChildOfClass("UIScale")
    if existing then existing:Destroy() end
    
    local sc = Instance.new("UIScale")
    sc.Parent = targetFrame
    SharedState.MobileScaleObjects[targetFrame] = sc
    
    local function updateScale()
        local baseScale = tonumber(Config.MobileGuiScale) or 0.8
        if Config.UseDPIScaling then
            local viewportSize = Camera.ViewportSize
            local dpiScale = math.min(viewportSize.X / 1280, viewportSize.Y / 720)
            sc.Scale = math.clamp(baseScale * dpiScale, 0.4, 1.5)
        else
            sc.Scale = math.clamp(baseScale, 0.4, 2)
        end
    end
    
    SharedState.RefreshMobileScale = function()
        for frame, sObj in pairs(SharedState.MobileScaleObjects) do
            if frame and frame.Parent and sObj and sObj.Parent == frame then
                local bScale = tonumber(Config.MobileGuiScale) or 0.8
                if Config.UseDPIScaling then
                    local vSize = Camera.ViewportSize
                    local dScale = math.min(vSize.X / 1280, vSize.Y / 720)
                    sObj.Scale = math.clamp(bScale * dScale, 0.4, 1.5)
                else
                    sObj.Scale = math.clamp(bScale, 0.4, 2)
                end
            else
                SharedState.MobileScaleObjects[frame] = nil
            end
        end
    end
    
    updateScale()
    Camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
end



