        -- Scan
        local function hasSellPrompt_rs(plot)
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if not podiums then return false end
            for _, podium in ipairs(podiums:GetChildren()) do
                if tonumber(podium.Name) then
                    local base = podium:FindFirstChild("Base")
                    local spawn_p = base and base:FindFirstChild("Spawn")
                    local att = spawn_p and spawn_p:FindFirstChild("PromptAttachment")
                    if att then
                        for _, pp in ipairs(att:GetChildren()) do
                            if pp:IsA("ProximityPrompt") and (pp.ActionText or ""):sub(1,4) == "Sell" then return true end
                        end
                    end
                end
            end
            return false
        end

        local function scan_rs()
            for _, ch in ipairs(scrollFrame_rs:GetChildren()) do
                if not ch:IsA("UIListLayout") and not ch:IsA("UIPadding") then ch:Destroy() end
            end
            allRows_rs = {}
            local plot = findMyPlot()
            if not plot then statusLabel_rs.Text = "вќЊ Base nГЈo encontrada"; return end
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if not podiums then statusLabel_rs.Text = "вќЊ AnimalPodiums nГЈo encontrado"; return end
            local entries = {}
            for _, podium in ipairs(podiums:GetChildren()) do
                local podiumNum = tonumber(podium.Name)
                if podiumNum then
                    local base = podium:FindFirstChild("Base")
                    local spawn_p = base and base:FindFirstChild("Spawn")
                    local att = spawn_p and spawn_p:FindFirstChild("PromptAttachment")
                    if att then
                        for _, pp in ipairs(att:GetChildren()) do
                            if pp:IsA("ProximityPrompt") and (pp.ActionText or ""):sub(1,4) == "Sell" then
                                local info = getPodiumAnimalData(plot, podiumNum)
                                if info then
                                    table.insert(entries, {podiumNum=podiumNum, prompt=pp, info=info})
                                end
                            end
                        end
                    end
                end
            end
            table.sort(entries, function(a,b) return a.podiumNum < b.podiumNum end)
            local found = #entries
            for _, entry in ipairs(entries) do addRow_rs(entry.podiumNum, entry.prompt, entry.info) end
            if found == 0 then
                statusLabel_rs.Text = "Nenhum brainrot para vender"
                sellAllBtn_rs.BackgroundColor3 = Theme.SurfaceHighlight
            else
                statusLabel_rs.Text = found .. " brainrot(s) pronto(s) para vender"
                sellAllBtn_rs.BackgroundColor3 = Theme.Accent1
            end
        end

        scanBtn_rs.MouseButton1Click:Connect(function()
            statusLabel_rs.Text = "Escaneando..."
            task.spawn(scan_rs)
        end)

        -- Startup scan
        task.spawn(function()
            local char = player.Character or player.CharacterAdded:Wait()
            char:WaitForChild("HumanoidRootPart", 15)
            local plots = Workspace:WaitForChild("Plots", 30)
            if not plots then statusLabel_rs.Text = "вќЊ Plots nГЈo encontrado"; return end
            for i = 1, 40 do
                if #plots:GetChildren() > 0 then break end
                task.wait(0.5)
            end
            for i = 1, 20 do
                if AnimalsData then break end
                task.wait(0.5)
            end
            local myPlot = findMyPlot()
            if not myPlot then statusLabel_rs.Text = "вќЊ Base nГЈo encontrada"; return end
            statusLabel_rs.Text = "Aguardando brainrots..."
            for i = 1, 60 do
                if hasSellPrompt_rs(myPlot) then break end
                task.wait(0.5)
                if i == 60 then statusLabel_rs.Text = "Nenhum brainrot nos podiums"; return end
            end
            scan_rs()
        end)
    end

    -- Toggle function
    local function toggleRemoteSell(enabled)
        Config.RemoteSellEnabled = enabled
        SaveConfig()
        if enabled then
            buildRemoteSellGUI()
            if sellGui then sellGui.Enabled = true end
            ShowNotification("REMOTE SELL", "ATIVADO")
        else
            if sellGui then sellGui.Enabled = false end
            ShowNotification("REMOTE SELL", "DESATIVADO")
        end
    end
    _G.toggleRemoteSell = toggleRemoteSell

    -- Restore state on load
    if Config.RemoteSellEnabled then
        task.defer(function() toggleRemoteSell(true) end)
    end

