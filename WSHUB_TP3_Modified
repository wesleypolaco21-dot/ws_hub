do
    local sellGuiBuilt = false
    local sellGui = nil

    local function buildRemoteSellGUI()
        if sellGuiBuilt then return end
        sellGuiBuilt = true

        local Players_rs           = Players
        local ReplicatedStorage_rs = ReplicatedStorage
        local TweenService_rs      = TweenService
        local UserInputService_rs  = UserInputService
