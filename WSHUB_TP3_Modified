            UserInputService_rs.InputEnded:Connect(function(input)
                if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and dragging_rs then
                    dragging_rs = false
                    pcall(writefile, SAVE_FILE_RS, mainFrame_rs.Position.X.Offset .. "," .. mainFrame_rs.Position.Y.Offset)
