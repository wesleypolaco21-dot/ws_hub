    qpMin.BackgroundColor3 = Color3.fromRGB(35,25,70); qpMin.BorderSizePixel = 0
    qpMin.Font = Enum.Font.GothamBlack; qpMin.TextSize = 14
    qpMin.Text = "вЂ“"; qpMin.TextColor3 = Color3.fromRGB(180,160,255)
