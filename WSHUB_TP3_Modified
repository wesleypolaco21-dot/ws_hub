        -- в”Ђв”Ђ Modules do jogo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        local AnimalsData   = nil
        local AnimalsShared = nil
        local NumberUtils   = nil
        local Synchronizer_rs  = nil

        task.spawn(function()
            pcall(function()
                local Datas  = ReplicatedStorage_rs:WaitForChild("Datas",  10)
                local Shared = ReplicatedStorage_rs:WaitForChild("Shared", 10)
                local Utils  = ReplicatedStorage_rs:WaitForChild("Utils",  10)
                local Pkgs   = ReplicatedStorage_rs:WaitForChild("Packages", 10)
                if Datas  then AnimalsData   = require(Datas:WaitForChild("Animals"))           end
                if Shared then AnimalsShared = require(Shared:WaitForChild("Animals"))          end
                if Utils  then NumberUtils   = require(Utils:WaitForChild("NumberUtils"))       end
                if Pkgs   then Synchronizer_rs = require(Pkgs:WaitForChild("Synchronizer"))    end
            end)
        end)

        -- в”Ђв”Ђ Encontrar base в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        local lockedPlot = nil
        local function findMyPlot()
            if lockedPlot and lockedPlot.Parent then return lockedPlot end
            local plots = Workspace:FindFirstChild("Plots")
            if not plots then return nil end
            local myName = player.Name:lower()
            local myId   = tostring(player.UserId)
            local myDN   = player.DisplayName:lower()
            for _, plot in ipairs(plots:GetChildren()) do
                if Synchronizer_rs then
                    local ok, ch = pcall(function() return Synchronizer_rs:Get(plot.Name) end)
                    if ok and ch then
                        local owner = ch:Get("Owner")
                        if owner then
                            if typeof(owner) == "Instance" and owner:IsA("Player") and owner == player then
                                lockedPlot = plot; return plot
                            elseif type(owner) == "table" and owner.UserId == player.UserId then
                                lockedPlot = plot; return plot
                            end
                        end
                    end
                end
                for _, v in ipairs(plot:GetDescendants()) do
                    if v:IsA("ObjectValue") and v.Value == player then
                        lockedPlot = plot; return plot
                    elseif v:IsA("IntValue") and tostring(v.Value) == myId then
                        lockedPlot = plot; return plot
                    elseif v:IsA("StringValue") then
                        local val = tostring(v.Value):lower()
                        if val == myName or val == myId or val == myDN then
                            lockedPlot = plot; return plot
                        end
                    end
                end
                local sign = plot:FindFirstChild("PlotSign")
                if sign then
                    local sg = sign:FindFirstChildWhichIsA("SurfaceGui", true)
                    if sg then
                        local lbl = sg:FindFirstChildWhichIsA("TextLabel", true)
                        if lbl then
                            local t = lbl.Text:lower()
                            if t:find(myName, 1, true) or t:find(myDN, 1, true) then
                                lockedPlot = plot; return plot
                            end
                        end
                    end
                end
            end
            local char = player.Character or player.CharacterAdded:Wait()
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local closest, closestDist = nil, math.huge
                for _, plot in ipairs(plots:GetChildren()) do
                    local ok, pos = pcall(function() return plot:GetPivot().Position end)
                    if ok then
                        local d = (pos - root.Position).Magnitude
                        if d < closestDist then closest = plot; closestDist = d end
                    end
                end
                if closest then lockedPlot = closest; return closest end
            end
            return nil
        end

        -- в”Ђв”Ђ Dados do podium в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        local function getPodiumAnimalData(plot, slotKey)
            if Synchronizer_rs then
                local ok, ch = pcall(function() return Synchronizer_rs:Get(plot.Name) end)
                if ok and ch then
                    local al = ch:Get("AnimalList")
                    if type(al) == "table" then
                        local entry = al[slotKey] or al[tonumber(slotKey)]
                        if type(entry) == "table" and entry.Index then
                            local aInfo = AnimalsData and AnimalsData[entry.Index]
                            local displayName = (aInfo and aInfo.DisplayName) or entry.Index
                            local genVal = 0; local genText = ""
                            if AnimalsShared then
                                pcall(function()
                                    genVal = AnimalsShared:GetGeneration(entry.Index, entry.Mutation, entry.Traits, nil)
                                end)
                            end
                            if NumberUtils and genVal > 0 then
                                genText = "$" .. NumberUtils:ToString(genVal) .. "/s"
                            end
                            local mut = entry.Mutation
                            if mut == "None" or mut == "" then mut = nil end
                            return { name = displayName, genText = genText, genVal = genVal, mutation = mut }
                        end
                    end
                end
            end
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                local podium = podiums:FindFirstChild(tostring(slotKey))
                if podium then
                    local base = podium:FindFirstChild("Base")
                    local spawn_p = base and base:FindFirstChild("Spawn")
                    if spawn_p then
                        for _, bb in ipairs(spawn_p:GetDescendants()) do
                            if (bb:IsA("BillboardGui") or bb:IsA("SurfaceGui")) then
                                for _, lbl in ipairs(bb:GetDescendants()) do
                                    if lbl:IsA("TextLabel") then
                                        local t = (lbl.Text or ""):gsub("<[^>]+>",""):match("^%s*(.-)%s*$")
                                        if t and #t > 2 and not t:find("^%$") and not t:find("/s$") then
                                            return { name = t, genText = "", genVal = 0, mutation = nil }
                                        end
                                    end
                                end
                            end
                        end
                        for _, obj in ipairs(podium:GetDescendants()) do
                            if obj:IsA("Model") and obj.Name ~= "" and obj.Name ~= podium.Name
                            and obj.Name ~= "Base" and obj.Name ~= "Spawn" then
                                local dn = (AnimalsData and AnimalsData[obj.Name] and AnimalsData[obj.Name].DisplayName) or obj.Name
                                return { name = dn, genText = "", genVal = 0, mutation = nil }
                            end
                        end
                    end
                end
            end
            return nil
        end

