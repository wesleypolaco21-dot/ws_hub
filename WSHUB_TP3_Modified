    qpTitle.Font = Enum.Font.GothamBlack; qpTitle.TextSize = 14
    qpTitle.TextColor3 = Color3.fromRGB(230,220,255); qpTitle.TextXAlignment = Enum.TextXAlignment.Left

    -- Minimize button
    local qpMin = Instance.new("TextButton", qpHeader)
